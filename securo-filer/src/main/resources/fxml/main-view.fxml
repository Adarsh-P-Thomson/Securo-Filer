<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.securofiler.controller.MainController" stylesheets="@../css/styles.css" styleClass="main-window">
    <left>
        <VBox styleClass="sidebar" spacing="15">
            <padding>
                <Insets top="30" right="15" bottom="30" left="15"/>
            </padding>
            <Label text="🛡️ Securo" styleClass="logo-text"/>
            
            <VBox spacing="10" VBox.vgrow="ALWAYS" alignment="CENTER_LEFT">
<padding><Insets top="40"/></padding>
                <Button text="🔑 Encrypt" maxWidth="Infinity" styleClass="nav-btn, active-nav"/>
                <Button text="🔓 Decrypt" maxWidth="Infinity" styleClass="nav-btn" onAction="#handleDecrypt"/>
                <Button text="⚙️ Settings" maxWidth="Infinity" styleClass="nav-btn"/>
            </VBox>
            
            <Label text="v1.0.0" styleClass="version-text" alignment="CENTER" maxWidth="Infinity"/>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <VBox spacing="15" alignment="CENTER_LEFT" maxWidth="550">
                <Label text="Encrypt Data" styleClass="title-text"/>
                <Label text="Select a target file or folder, and provide a secure key to begin AES-256-GCM encryption." styleClass="subtitle-text" wrapText="true"/>
                
                <VBox spacing="5">
                    <Label text="Target File / Folder" styleClass="field-label"/>
                    <HBox spacing="10">
                        <TextField fx:id="filePathField" promptText="Path to your file or directory..." HBox.hgrow="ALWAYS" styleClass="input-field"/>
                        <Button text="Browse..." styleClass="action-btn"/>
                    </HBox>
                </VBox>
                
                <VBox spacing="5">
                    <Label text="Encryption Key Source" styleClass="field-label"/>
                    <ComboBox maxWidth="Infinity" promptText="Standard Password" styleClass="input-field">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Standard Password"/>
                                <String fx:value="Key Image (Steganographic Seed)"/>
                            </FXCollections>
                        </items>
                        <value>
                            <String fx:value="Standard Password"/>
                        </value>
                    </ComboBox>
                </VBox>
                
                <VBox spacing="5" fx:id="passwordContainer">
                    <Label text="Secret Key" styleClass="field-label"/>
                    <PasswordField promptText="Enter your secure password..." styleClass="input-field"/>
                </VBox>
                
                <Region minHeight="20"/>
                
                <HBox alignment="CENTER_RIGHT" spacing="15">
                    <Button text="Secure &amp; Encrypt" onAction="#handleEncrypt" styleClass="primary-btn"/>
                </HBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>